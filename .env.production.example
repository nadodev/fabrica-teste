APP_HOST=loja.exemplo.com.br
ACME_EMAIL=infra@exemplo.com.br
IMAGE_TAG=latest

APP_NAME="Fábrica de Fardamentos"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://loja.exemplo.com.br
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=fabrica_loja
DB_USERNAME=fabrica_loja
DB_PASSWORD=
DB_ROOT_PASSWORD=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
QUEUE_CONNECTION=redis
REDIS_QUEUE_RETRY_AFTER=180

FILESYSTEM_DISK=public
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

PAYMENT_GATEWAY=asaas
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_LIVE_ENABLED=true
ASAAS_WEBHOOK_MAX_ATTEMPTS=10
ASAAS_WEBHOOK_STALE_MINUTES=15
ASAAS_DUE_DAYS=3
MELHOR_ENVIO_TOKEN=

SECURITY_CSP_REPORT_ONLY=false
ADMIN_AUDIT_RETENTION_DAYS=365
ADMIN_TWO_FACTOR_TTL_MINUTES=10
ADMIN_TWO_FACTOR_MAX_ATTEMPTS=5
ADMIN_TWO_FACTOR_RETENTION_DAYS=30
